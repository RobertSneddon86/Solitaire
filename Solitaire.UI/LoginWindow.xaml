<Window x:Class="Nclan.Ac.RobertS.Solitaire.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Solitaire - Login"
        Width="1200"
        Height="800"
        Background="#186F45"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- Title -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,80,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="♠" FontSize="40" Foreground="White" Margin="0,0,10,0"/>
                <TextBlock Text="Solitaire" FontSize="36" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="♠" FontSize="40" Foreground="White" Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Login Card -->
        <Border Width="450"
                Background="#EAEAEA"
                CornerRadius="12"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Welcome Back"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Sign in to track your game statistics"
                           Foreground="Gray"
                           Margin="0,0,0,20"/>

                <!-- Login / Sign Up Toggle -->
                <Border Background="#D6D6D6"
                        CornerRadius="20"
                        Padding="3"
                        Margin="0,0,0,20">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="LoginToggleButton"
                                Content="Login"
                                Click="LoginToggle_Click"
                                Background="White"
                                BorderBrush="Transparent"
                                Margin="2"
                                Grid.Column="0"/>

                        <Button x:Name="SignUpToggleButton"
                                Content="Sign Up"
                                Click="SignUpToggle_Click"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Grid.Column="1"/>
                    </Grid>

                </Border>

                <!-- Username -->
                <TextBlock Text="Username"/>
                <TextBox x:Name="UsernameTextBox"
                         Height="35"
                         Margin="0,5,0,10"/>

                <!-- Age (Signup only) -->
                <StackPanel x:Name="AgeSection"
                            Visibility="Collapsed">

                    <TextBlock Text="Date of Birth"/>
                    <DatePicker x:Name="AgeTextBox"
                                Height="35"
                                HorizontalAlignment="Stretch"
                                Margin="0,5,0,10"
                                DisplayDateEnd="{x:Static sys:DateTime.Today}"/>

                </StackPanel>

                <!-- Password -->
                <TextBlock Text="Password"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="35"
                             Margin="0,5,0,20"/>

                <!-- Buttons -->
                <Button x:Name="MainActionButton"
                        Content="Sign In"
                        Height="40"
                        Background="#1B1B1B"
                        Foreground="White"
                        Click="MainActionButton_Click"/>

                <TextBlock Text="OR"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>

                <Button Content="Play as Guest"
                        Height="40"
                        Background="White"
                        BorderBrush="Gray"
                        FontWeight="Bold"
                        Click="Guest_Click"/>

                <Button Content="Exit"
                        Height="40"
                        Background="#D9534F"
                        Foreground="White"
                        Margin="0,10,0,0"
                        Click="Exit_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>