<Window x:Class="Nclan.Ac.RobertS.Solitaire.UI.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Solitaire - Game"
        Width="1200"
        Height="800"
        Background="#186F45"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid.RowDefinitions>
            <!-- Top Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Stats Cards -->
            <RowDefinition Height="Auto"/>
            <!-- Game Area -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP BAR ================= -->
        <Grid Grid.Row="0" Margin="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Logo + Welcome -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="♠"
                           FontSize="30"
                           Foreground="White"
                           Margin="0,0,10,0"/>
                <StackPanel>
                    
                    <TextBlock Text="Solitaire"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="WelcomeTextBlock" Text="Welcome, Guest!"
                               Foreground="LightGray"/>
                    
                </StackPanel>
            </StackPanel>

            <!-- Right: Buttons -->
            <StackPanel Orientation="Horizontal"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center">

                <ComboBox x:Name="DifficultyBox"
                      Width="150"
                      Margin="5"
                      SelectionChanged="DifficultyBox_SelectionChanged">
                    <ComboBoxItem Content="Easy"/>
                    <ComboBoxItem Content="Medium" IsSelected="True"/>
                </ComboBox>

                <CheckBox x:Name="VegasModeCheck"
                          Content="Vegas Mode"
                          Margin="10,0"
                          Foreground="White"
                          VerticalAlignment="Center"
                          Checked="VegasModeCheck_Checked"
                          Unchecked="VegasModeCheck_Unchecked"/>

                <Button Content="New Game"
            Margin="5"
            Padding="15,5"
            Click="NewGame_Click"/>

                <Button Content="Statistics"
            Margin="5"
            Padding="15,5"
            Click="Statistics_Click"/>

                <Button Content="Logout"
            Margin="5"
            Padding="15,5"
            Click="Logout_Click"/>

                <Button Content="Quit"
            Margin="5"
            Padding="15,5"
            Background="#D9534F"
            Foreground="White"
            Click="Quit_Click"/>
            </StackPanel>
        </Grid>

        <!-- ================= STATS CARDS ================= -->
        <UniformGrid Grid.Row="1"
                     Columns="4"
                     Margin="40,10,40,20">

            <Border Background="#EAEAEA"
                    CornerRadius="12"
                    Padding="20"
                    Margin="10">
                <StackPanel>
                    <TextBlock Text="Time"/>
                    <TextBlock x:Name="TimeTextBlock"
                               Text="0:00"
                               FontSize="22"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#EAEAEA"
                    CornerRadius="12"
                    Padding="20"
                    Margin="10">
                <StackPanel>
                    <TextBlock Text="Moves"/>
                    <TextBlock x:Name="MovesTextBlock"
                               Text="0"
                               FontSize="22"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#EAEAEA"
                    CornerRadius="12"
                    Padding="20"
                    Margin="10">
                <StackPanel>
                    <TextBlock Text="Score"/>
                    <TextBlock x:Name="ScoreTextBlock"
                               Text="0"
                               FontSize="22"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#EAEAEA"
        CornerRadius="12"
        Padding="20"
        Margin="10">

                <StackPanel>
                    <TextBlock Text="Balance"/>
                    <TextBlock x:Name="BalanceTextBlock"
                   Text="£0"
                   FontSize="22"
                   FontWeight="Bold"/>
                </StackPanel>

            </Border>

        </UniformGrid>

        <!-- ================= GAME AREA ================= -->
        <Grid Grid.Row="2" Margin="40">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Top Card Row -->
                <RowDefinition Height="*"/>
                <!-- Tableau -->
            </Grid.RowDefinitions>

            <!-- Stock / Waste / Foundations -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Stock -->
                <Grid>
                    <Border x:Name="StockBorder"
                            Width="80"
                            Height="120"
                            Background="#0F5C3A"
                            CornerRadius="8"
                            Margin="5"
                            MouseDown="StockBorder_Click"/>

                    <TextBlock x:Name="StockCountText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Margin="0,125,0,0"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="14"/>
                </Grid>

                <!-- Waste -->
                <Grid Grid.Column="1">
                    <Border x:Name="WasteBorder"
                            Width="80"
                            Height="120"
                            Background="#0F5C3A"
                            CornerRadius="8"
                            Margin="5"/>

                    <TextBlock x:Name="WasteCountText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Margin="0,125,0,0"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="14"/>
                </Grid>

                <!-- Spacer -->
                <Grid Grid.Column="2"/>

                <!-- Foundations -->
                <Border x:Name="Foundation0"
                        Width="80"
                        Height="120"
                        Background="#0F5C3A"
                        CornerRadius="8"
                        Margin="5"
                        Grid.Column="3"
                        MouseDown="Foundation_Click"/>
                <Border x:Name="Foundation1"
                        Width="80"
                        Height="120"
                        Background="#0F5C3A"
                        CornerRadius="8"
                        Margin="5"
                        Grid.Column="4"
                        MouseDown="Foundation_Click"/>
                <Border x:Name="Foundation2"
                        Width="80"
                        Height="120"
                        Background="#0F5C3A"
                        CornerRadius="8"
                        Margin="5"
                        Grid.Column="5"
                        MouseDown="Foundation_Click"/>
                <Border x:Name="Foundation3"
                        Width="80"
                        Height="120"
                        Background="#0F5C3A"
                        CornerRadius="8"
                        Margin="5"
                        Grid.Column="6"
                        MouseDown="Foundation_Click"/>
            </Grid>

            <!-- Tableau Columns -->
            <UniformGrid x:Name="TableauGrid"
                        Grid.Row="1"
                        Columns="7"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Width="760"
                        Margin="0,5,0,0"/>
        </Grid>
    </Grid>
</Window>