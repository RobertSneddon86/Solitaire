<Window x:Class="Nclan.Ac.RobertS.Solitaire.UI.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Solitaire - Statistics"
        Width="1200"
        Height="800"
        Background="#186F45"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>

        <!-- Centered Main Container -->
            <Grid HorizontalAlignment="Center"
              Width="850">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ================= HEADER ================= -->
                <DockPanel Grid.Row="0" Margin="0,30,0,40" LastChildFill="False">

                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Statistics"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"/>

                        <TextBlock x:Name="PlayerPerformanceText"
                                    Foreground="LightGray"/>
                    </StackPanel>

                    <Button Content="← Back to Game"
            DockPanel.Dock="Right"
            Padding="12,6"
            Click="Back_Click"/>

                </DockPanel>
                <!-- ================= SUMMARY CARDS ================= -->
                <UniformGrid Grid.Row="1"
                         Columns="5"
                         Margin="0,0,0,30">

                    <Border Background="#EAEAEA" CornerRadius="12" Padding="20" Margin="10">
                        <StackPanel>
                            <TextBlock Text="Games Played"/>
                            <TextBlock x:Name="GamesPlayedText"
                                       Text="0"
                                       FontSize="20"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#EAEAEA" CornerRadius="12" Padding="20" Margin="10">
                        <StackPanel>
                            <TextBlock Text="Games Won"/>
                            <TextBlock x:Name="GamesWonText"
                                       Text="0"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="Green"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#EAEAEA" CornerRadius="12" Padding="20" Margin="10">
                        <StackPanel>
                            <TextBlock Text="Best Time"/>
                            <TextBlock x:Name="BestTimeText"
                                       Text="0:00"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="Blue"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#EAEAEA" CornerRadius="12" Padding="20" Margin="10,10,10,10">
                        <StackPanel>
                            <TextBlock Text="Best Score"/>
                            <TextBlock x:Name="BestScoreText"
                                       Text="0"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="Purple"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#EAEAEA" CornerRadius="12" Padding="20" Margin="10">
                        <StackPanel>
                            <TextBlock Text="Balance"/>
                            <TextBlock x:Name="BalanceText"
                   Text="£0"
                   FontSize="20"
                   FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- ================= WIN RATE ================= -->
                <Border Grid.Row="2"
                    Background="#EAEAEA"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,30">

                    <StackPanel>
                        <TextBlock Text="Win Rate"
                               FontWeight="Bold"/>

                        <TextBlock x:Name="WinRateText"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,5,0,10"/>

                        <ProgressBar x:Name="WinRateBar"
                                     Height="10"
                                     Minimum="0"
                                     Maximum="100"/>
                    </StackPanel>

                </Border>

                <!-- ================= ADDITIONAL STATISTICS ================= -->
                <Border Grid.Row="3"
                    Background="#EAEAEA"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,30">

                    <StackPanel>

                        <TextBlock Text="Additional Statistics"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT COLUMN -->
                            <StackPanel Grid.Column="0" Margin="0,0,40,0">
                                <TextBlock Text="Total Moves" Foreground="Gray"/>
                                <TextBlock x:Name="TotalMovesText"
                                           Text="0"
                                           FontSize="18"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Games Lost" Foreground="Gray"/>
                                <TextBlock x:Name="GamesLostText"
                                           Text="0"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="Red"/>
                            </StackPanel>

                            <!-- RIGHT COLUMN -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Average Moves per Game" Foreground="Gray"/>
                                <TextBlock x:Name="AverageMovesText"
                                           Text="0"
                                           FontSize="18"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Loss Rate" Foreground="Gray"/>
                                <TextBlock x:Name="LossRateText"
                                           Text="0%"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="Red"/>
                            </StackPanel>

                        </Grid>

                    </StackPanel>

                </Border>

                <!-- ================= ACHIEVEMENTS ================= -->
                <Border x:Name="AchievementsSection"
                        Grid.Row="4"
                        Background="#EAEAEA"
                        CornerRadius="12"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="Achievements"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                        <UniformGrid Columns="4">

                            <Border x:Name="FirstGameBorder" Margin="5" CornerRadius="8" Background="#E0E0E0">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🎮" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="First Game" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="FirstWinBorder" Margin="5" CornerRadius="8" Background="#E0E0E0">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🏆" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="First Win" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="TenWinsBorder" Margin="5" CornerRadius="8" Background="#E0E0E0">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="⭐" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="10 Wins" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="FiftyWinBorder" Margin="5" CornerRadius="8" Background="#E0E0E0">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🎯" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="50% Win Rate" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </UniformGrid>

                    </StackPanel>

                </Border>

            </Grid>
        </Grid>
    </ScrollViewer>
</Window>